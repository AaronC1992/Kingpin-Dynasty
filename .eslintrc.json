{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "ignorePatterns": ["node_modules/**"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }]
  },
  "globals": {
    "player": "writable",
    "EventBus": "readonly",
    "GameBalance": "readonly",
    "GameMeta": "readonly",
    "GameLogging": "readonly",
    "sendMP": "readonly",
    "onlineWorldState": "readonly",
    "_currentAllianceData": "readonly",
    "initializeOnlineWorld": "readonly",
    "connectMultiplayerAfterGame": "readonly",
    "connectToOnlineWorld": "readonly",
    "requestJailRoster": "readonly",
    "syncJailStatus": "readonly",
    "showOnlineWorld": "readonly",
    "renderMarketplaceTab": "readonly",
    "broadcastDeathNewspaper": "readonly",
    "broadcastJailNewspaper": "readonly",
    "closeScreen": "writable",
    "calculateTotalTerritoryIncome": "readonly",
    "currentEvents": "writable",
    "eventHistory": "writable",
    "weeklyChallenges": "writable",
    "isConnected": "readonly",
    "getMiniGameStatsHTML": "readonly"
  },
  "overrides": [
    {
      "files": ["server.js", "db.js", "userDB.js", "worldPersistence.js", "server-sanity-test.js"],
      "parserOptions": {
        "sourceType": "script"
      },
      "env": {
        "browser": false,
        "node": true
      }
    },
    {
      "files": ["multiplayer.js"],
      "parserOptions": {
        "sourceType": "script"
      },
      "rules": {
        "no-unused-vars": "off",
        "no-case-declarations": "off",
        "no-empty": "off"
      },
      "globals": {
        "updateUI": "readonly",
        "logAction": "readonly",
        "hideAllScreens": "readonly",
        "showBriefNotification": "readonly",
        "stopJailTimer": "readonly",
        "showJailNewspaper": "readonly",
        "showDeathNewspaper": "readonly",
        "showDeathScreen": "readonly",
        "renderTerritoriesScreen": "readonly",
        "goBackToMainMenu": "readonly",
        "updateJailTimer": "readonly",
        "generateJailPrisoners": "readonly",
        "showJailScreen": "readonly",
        "updateMobileActionLog": "readonly",
        "escapeHTML": "readonly",
        "ui": "readonly",
        "ModalSystem": "readonly",
        "MobileSystem": "readonly",
        "updatePrisonerList": "readonly",
        "updateJailbreakPrisonerList": "readonly",
        "gainExperience": "readonly",
        "showToast": "readonly",
        "refreshStoreAfterPurchase": "readonly",
        "calculatePower": "readonly",
        "saveGame": "readonly",
        "showJobs": "readonly",
        "DISTRICTS": "readonly"
      }
    }
  ]
}
